{
  "name": "qk-money-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:demo": "vite build --mode demo",
    "preview": "vite preview",
    "tailwind": "npx tailwindcss -i ./src/style/tailwind.css --watch",
    "electron:build": "electron-builder"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@vueuse/core": "^12.8.2",
    "@vueuse/integrations": "^12.8.2",
    "axios": "^1.13.5",
    "big.js": "^7.0.1",
    "dayjs": "^1.11.19",
    "echarts": "^5.6.0",
    "element-plus": "^2.13.2",
    "fast-glob": "^3.3.3",
    "nprogress": "^0.2.0",
    "number-precision": "^1.6.0",
    "pinia": "^3.0.4",
    "print-js": "^1.6.0",
    "universal-cookie": "^7.2.2",
    "vue": "^3.5.28",
    "vue-echarts": "^7.0.3",
    "vue-router": "^4.6.4",
    "vue3-perfect-scrollbar": "^2.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "autoprefixer": "^10.4.24",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "less": "^4.5.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "unplugin-auto-import": "^19.3.0",
    "unplugin-vue-components": "^28.8.0",
    "vite": "^6.4.1",
    "vite-plugin-svg-icons": "^2.0.1"
  },
  "build": {
    "appId": "com.money.pos",
    "productName": "MoneyPOS",
    "directories": {
      "output": "release"
    },
    "extraFiles": [
      {
        "from": "../build-env/mariadb",
        "to": "mariadb"
      },
      {
        "from": "../build-env/jre",
        "to": "jre"
      }
    ],
    "extraResources": [
      {
        "from": "../money-pos/qk-money-app/money-app-biz/target/money-pos.jar",
        "to": "backend/money-pos.jar"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MoneyPOS 收银系统"
    }
  }
}
